{
  "meta": {
    "name": "format-json-package",
    "description": "Version bump updates package.json version field"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\n      \"name\": \"myapp\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"package.json\", \"format\": \"json\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "myapp",
      "path": ".",
      "initial_version": "2.0.0",
      "tag": "v2.0.0",
      "versioned_files": [
        {
          "path": "package.json",
          "format": "json",
          "content": "{\n  \"name\": \"myapp\",\n  \"version\": \"2.0.0\"\n}\n"
        }
      ]
    }
  ],
  "commits": [
    { "message": "fix: resolve memory leak", "files": ["src/index.ts"] }
  ],
  "expect": {
    "check_contains": ["myapp", "2.0.1", "patch"],
    "check_not_contains": ["Nothing to release"]
  }
}
