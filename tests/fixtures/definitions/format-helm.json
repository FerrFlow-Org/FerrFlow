{
  "meta": {
    "name": "format-helm",
    "description": "Version bump updates Chart.yaml version field"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\n      \"name\": \"mychart\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"Chart.yaml\", \"format\": \"helm\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "mychart",
      "path": ".",
      "initial_version": "0.5.0",
      "tag": "v0.5.0",
      "versioned_files": [
        {
          "path": "Chart.yaml",
          "format": "helm",
          "content": "apiVersion: v2\nname: mychart\nversion: 0.5.0\nappVersion: \"1.0\"\n"
        }
      ]
    }
  ],
  "commits": [
    { "message": "feat: add ingress template", "files": ["templates/ingress.yaml"] }
  ],
  "expect": {
    "check_contains": ["mychart", "0.6.0", "minor"],
    "check_not_contains": ["Nothing to release"]
  }
}
