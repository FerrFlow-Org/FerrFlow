{
  "meta": {
    "name": "multi-versioned-files",
    "description": "Single package with multiple versioned files in different formats"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\n      \"name\": \"myapp\",\n      \"path\": \".\",\n      \"versioned_files\": [\n        {\"path\": \"Cargo.toml\", \"format\": \"toml\"},\n        {\"path\": \"package.json\", \"format\": \"json\"},\n        {\"path\": \"VERSION\", \"format\": \"txt\"}\n      ]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "myapp",
      "path": ".",
      "initial_version": "1.0.0",
      "tag": "v1.0.0",
      "versioned_files": [
        { "path": "Cargo.toml", "format": "toml", "content": "[package]\nname = \"myapp\"\nversion = \"1.0.0\"\n" },
        { "path": "package.json", "format": "json", "content": "{\n  \"name\": \"myapp\",\n  \"version\": \"1.0.0\"\n}\n" },
        { "path": "VERSION", "format": "txt", "content": "1.0.0\n" }
      ]
    }
  ],
  "commits": [
    { "message": "feat: add multi-format support", "files": ["src/main.rs"] }
  ],
  "expect": {
    "check_contains": ["myapp", "1.1.0", "minor"],
    "check_not_contains": ["Nothing to release"]
  }
}
