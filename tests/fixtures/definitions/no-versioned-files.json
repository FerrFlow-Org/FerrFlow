{
  "meta": {
    "name": "no-versioned-files",
    "description": "Package with no versioned_files still gets a version bump and tag"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\"name\": \"app\", \"path\": \".\", \"versioned_files\": []}\n  ]\n}\n"
  },
  "packages": [
    { "name": "app", "path": ".", "initial_version": "1.0.0", "tag": "v1.0.0" }
  ],
  "commits": [
    { "message": "feat: add feature", "files": ["src/main.rs"] }
  ],
  "expect": {
    "check_contains": ["app", "1.1.0"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 1
  }
}
