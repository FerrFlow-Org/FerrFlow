{
  "meta": {
    "name": "format-csproj",
    "description": "Version bump updates a .csproj file correctly"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\n      \"name\": \"mylib\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"MyLib.csproj\", \"format\": \"csproj\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "mylib",
      "path": ".",
      "initial_version": "1.0.0",
      "tag": "v1.0.0",
      "versioned_files": [
        {
          "path": "MyLib.csproj",
          "format": "csproj",
          "content": "<Project Sdk=\"Microsoft.NET.Sdk\">\n  <PropertyGroup>\n    <Version>1.0.0</Version>\n  </PropertyGroup>\n</Project>\n"
        }
      ]
    }
  ],
  "commits": [
    { "message": "feat: add serialization support", "files": ["src/Serializer.cs"] }
  ],
  "expect": {
    "check_contains": ["mylib", "1.1.0", "minor"],
    "check_not_contains": ["Nothing to release"]
  }
}
