{
  "meta": {
    "name": "format-gradle",
    "description": "Version bump updates build.gradle version property"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\n      \"name\": \"myapp\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"build.gradle\", \"format\": \"gradle\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "myapp",
      "path": ".",
      "initial_version": "2.3.0",
      "tag": "v2.3.0",
      "versioned_files": [
        {
          "path": "build.gradle",
          "format": "gradle",
          "content": "plugins {\n    id 'java'\n}\n\nversion = '2.3.0'\n"
        }
      ]
    }
  ],
  "commits": [
    { "message": "feat!: drop Java 8 support", "files": ["src/main/java/App.java"] }
  ],
  "expect": {
    "check_contains": ["myapp", "3.0.0", "major"],
    "check_not_contains": ["Nothing to release"]
  }
}
