{
  "meta": {
    "name": "format-txt",
    "description": "Version bump updates plain text VERSION file"
  },
  "config": {
    "content": "{\n  \"package\": [\n    {\n      \"name\": \"myapp\",\n      \"path\": \".\",\n      \"versioned_files\": [{\"path\": \"VERSION\", \"format\": \"txt\"}]\n    }\n  ]\n}\n"
  },
  "packages": [
    {
      "name": "myapp",
      "path": ".",
      "initial_version": "1.2.3",
      "tag": "v1.2.3",
      "versioned_files": [
        {
          "path": "VERSION",
          "format": "txt",
          "content": "1.2.3\n"
        }
      ]
    }
  ],
  "commits": [
    { "message": "feat: add export command", "files": ["src/export.rs"] }
  ],
  "expect": {
    "check_contains": ["myapp", "1.3.0", "minor"],
    "check_not_contains": ["Nothing to release"]
  }
}
